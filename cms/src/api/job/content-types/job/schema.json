{
  "kind": "collectionType",
  "collectionName": "jobs",
  "info": {
    "singularName": "job",
    "pluralName": "jobs",
    "displayName": "Job"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "location": {
      "type": "string"
    },
    "employmentType": {
      "type": "enumeration",
      "enum": [
        "Full-time",
        "Part-time",
        "Contract",
        "Temporary",
        "Internship"
      ]
    },
    "salaryPerYear": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Full Time",
        "Part Time"
      ]
    }
  }
}
