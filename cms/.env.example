# Server
HOST=0.0.0.0
PORT=1337

# Strapi secrets (generate strong random strings for each)
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database — set to "sqlite" for local dev without Docker, "postgres" for Docker/Railway
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5450
DATABASE_NAME=strapi
DATABASE_USERNAME=wastetrade
DATABASE_PASSWORD=wastetrade123
# DATABASE_URL=            # Railway: use ${{Postgres.DATABASE_URL}} instead of discrete vars
# DATABASE_SSL=true        # Railway: enable for managed Postgres

# CORS — comma-separated origins allowed to call the Strapi API
CORS_ORIGINS=http://localhost:4200,http://localhost:3001
