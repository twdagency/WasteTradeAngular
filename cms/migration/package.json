{
  "name": "wp-to-strapi-migration",
  "version": "1.0.0",
  "description": "Migrate content from WordPress to Strapi - imports only media used in content",
  "type": "module",
  "scripts": {
    "migrate": "node index.js",
    "migrate:dry-run": "node index.js --dry-run",
    "migrate:sql": "node sql-migrate.js",
    "migrate:sql:dry-run": "node sql-migrate.js --dry-run",
    "extract": "node sql-migrate.js --extract-only",
    "upload:remote": "node upload-to-remote.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.0",
    "mysql2": "^3.11.0"
  }
}
