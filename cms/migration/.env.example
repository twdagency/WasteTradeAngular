# WordPress source (existing WasteTrade site)
WORDPRESS_URL=https://www.wastetrade.com

# Optional: if WP requires auth (Application Passwords or basic auth)
# WORDPRESS_AUTH=username:application_password

# Strapi destination
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your-api-token-from-strapi-admin

# Optional: use admin login instead of API token (email + password)
# STRAPI_EMAIL=admin@example.com
# STRAPI_PASSWORD=your-admin-password
