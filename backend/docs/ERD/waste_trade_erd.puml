' ===== Authentication Models =====
entity "forgot_password_request" as forgotPasswordRequest #lightgrey {
  id: number <<PK>>
  --
  *email: string
  *token: string
  *expires_at: Date
  *is_used: boolean <<default: false>>
  *created_at: Date <<default: now()>>
  *updated_at: Date <<default: now()>>
