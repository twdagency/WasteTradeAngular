entity "register_haulier_request" as registerHaulierRequest #lightgrey {
  id: number <<PK>>
  --
  *email: string
  *first_name: string
  *last_name: string
  *phone_number: string
  *company_name: string
  company_registration_number?: string
  fleet_type?: string
  areas_covered?: string[]
  container_types?: string[]
  *status: string
  rejection_reason?: string
  admin_message?: string
  *created_at: Date <<default: now()>>
  *updated_at: Date <<default: now()>>
