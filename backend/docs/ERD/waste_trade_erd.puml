entity "reset_password_request" as resetPasswordRequest #lightgrey {
  id: number <<PK>>
  --
  *email: string
  *token: string
  *expires_at: Date
  *is_used: boolean <<default: false>>
  *created_at: Date <<default: now()>>
  *updated_at: Date <<default: now()>>
}

' ===== Other Models =====
entity "waste_trade_notifications" as wasteTradeNotifications #lightgrey {
  id: number <<PK>>
  --
  ~*user_id: number <<FK>>
  --
  *type: string
  *title: string
  *content: string
  metadata?: object
  *is_read: boolean <<default: false>>
  read_at?: Date
  *created_at: Date <<default: now()>>
  *updated_at: Date <<default: now()>>
}

entity "data_draft" as dataDraft #lightgrey {
  id: number <<PK>>
  --
  ~*user_id: number <<FK>>
  --
  draft_type?: string
  draft_data?: object
  *created_at: Date <<default: now()>>
  *updated_at: Date <<default: now()>>
}

' ===== Relationships =====
' User Management
users ||--o{ companyUsers : has
companies ||--o{ companyUsers : employs

' Company Management
companies ||--o{ companyDocuments : uploads
companies ||--o{ companyLocations : has
users ||--o{ companyDocuments : "uploads/reviews"
companyLocations ||--o{ companyLocationDocuments : contains

' Material Management
materials ||--o{ materials : "parent/child"
users ||--o{ materials : creates
users ||--o{ materialUsers : has
materials ||--o{ materialUsers : has

' Listings Management
companies ||--o{ listings : sells
companyLocations ||--o{ listings : associated_with
users ||--o{ listings : creates
listings ||--o{ listingDocuments : contains

' Offers and Transactions
listings ||--o{ offers : "receives"
companies ||--o{ offers : makes
users ||--o{ offers : creates
offers ||--o| transactions : "converts to"
listings ||--o{ transactions : "sold in"
companies ||--o{ transactions : "buys/sells"
companies |o--o{ transactions : transports

' Transport Management
offers ||--o{ haulageOffers : "transport bids"
companies ||--o{ haulageOffers : "provides transport"
users ||--o{ haulageOffers : creates
haulageOffers ||--o{ haulageBidActions : tracks

' Communication
listings ||--o{ conversations : "discussed in"
offers ||--o{ conversations : "negotiated in"
transactions ||--o{ conversations : "managed in"
conversations ||--o{ messages : contains
users ||--o{ messages : sends

' Audit and Logging
users ||--o{ auditTrails : generates
companies ||--o{ auditTrails : "associated with"

' Registration and Requests
users ||--o{ registerTradingRequest : "creates from"
users ||--o{ registerHaulierRequest : "creates from"
companies ||--o{ updateCompanyRequest : "requests updates for"

' Notifications
users ||--o{ wasteTradeNotifications : receives

' Data Management
users ||--o{ dataDraft : creates

@enduml