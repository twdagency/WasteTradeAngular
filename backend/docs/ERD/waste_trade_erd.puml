  *last_name: string
  *phone_number: string
  *company_name: string
  company_registration_number?: string
  company_website?: string
  *is_haulier: boolean
  *material_interests: string[]
  other_material?: string
  *status: string
  rejection_reason?: string
  admin_message?: string
  *created_at: Date <<default: now()>>
  *updated_at: Date <<default: now()>>
