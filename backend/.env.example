# For local dev with MinIO (docker compose up -d), use:
#   AWS_S3_BUCKET=wastetrade
#   AWS_S3_REGION=us-east-1
#   AWS_S3_ACCESS_KEY_ID=minioadmin
#   AWS_S3_SECRET_ACCESS_KEY=minioadmin
#   AWS_S3_ENDPOINT=http://localhost:9000
#   AWS_S3_PUBLIC_URL=http://localhost:9000
# For Railway MinIO, set ENDPOINT to the private URL and PUBLIC_URL to the public domain.
# For real AWS S3, leave ENDPOINT and PUBLIC_URL empty.
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=

SENDGRID_API_KEY=
SENDGRID_SENDER=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

DEEPL_API_KEY=
DEEPL_I18N_S3_BUCKET=
DEEPL_I18N_S3_PATH=

# Salesforce Integration Configuration
# =================================

# Salesforce Connected App Credentials
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret

# Salesforce User Credentials  
SALESFORCE_USERNAME=your_username@letsrecycleit.com.uat
SALESFORCE_PASSWORD=your_password
SALESFORCE_SECURITY_TOKEN=your_security_token

# Salesforce Environment URLs
SALESFORCE_SANDBOX_URL=https://test.salesforce.com
SALESFORCE_PRODUCTION_URL=https://login.salesforce.com

# API Configuration
SALESFORCE_API_VERSION=58.0

# Integration Control
SALESFORCE_SYNC_ENABLED=true

# Exchange Rate API Configuration
# =================================
EXCHANGE_RATE_API_URL=
EXCHANGE_RATE_BASE_CURRENCY=GBP

# VATSense API Configuration
VATSENSE_API_KEY=

COMPLETE_ACCOUNT_DRAFT_EXPIRED_DAYS=31d