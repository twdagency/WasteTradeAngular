{
  "name": "backend",
  "version": "0.0.1",
  "description": "backend",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "18 || 20 || 22"
  },
  "scripts": {
    "prebuild": "pnpm clean",
    "prestart": "npm run build",
    "start": "node -r source-map-support/register .",
    "dev": "nodemon --config nodemon.json",
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "pnpm eslint && pnpm prettier:check",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint:fix": "pnpm eslint:fix && pnpm prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "prettier --check \"src/**/*.ts\"",
    "prettier:fix": "prettier --write \"src/**/*.ts\"",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "lb-eslint --report-unused-disable-directives --fix .",
    "test": "pnpm run build && lb-mocha --allow-console-logs \"dist/__tests__/unit\"",
    "test:acceptance": "pnpm run build && lb-mocha --allow-console-logs \"dist/__tests__/acceptance\"",
    "test:all": "pnpm run build && lb-mocha --allow-console-logs \"dist/__tests__\"",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/unit/**/*.js",
    "test:coverage": "pnpm run build && nyc lb-mocha --allow-console-logs \"dist/__tests__/unit\"",
    "docker:build": "docker build -t backend .",
    "docker:run": "docker run -p 3000:3000 -d backend",
    "migrate": "pnpm build && node ./dist/migrate",
    "migrate:debug": "pnpm build && node --inspect ./dist/migrate",
    "migrate:safe": "pnpm build && node ./dist/migrate-safe",
    "migrate:ci": "node ./dist/migrate",
    "openapi-spec": "pnpm build && node ./dist/openapi-spec",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "sf:deploy-apex": "node scripts/deploy-apex.js",
    "sf:export-fields": "node scripts/export-field-configs.js",
    "sf:setup-fields": "node scripts/setup-salesforce-fields.js"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/authentication": "^11.0.13",
    "@loopback/authentication-jwt": "^0.15.13",
    "@loopback/authorization": "^0.15.13",
    "@loopback/boot": "^7.0.9",
    "@loopback/build": "^11.0.9",
    "@loopback/core": "^6.1.6",
    "@loopback/cron": "^0.12.14",
    "@loopback/repository": "^7.0.9",
    "@loopback/rest": "^14.0.9",
    "@loopback/rest-explorer": "^7.0.9",
    "@loopback/security": "^0.11.13",
    "@loopback/service-proxy": "^7.0.9",
    "@sendgrid/mail": "^8.1.5",
    "@types/marked": "^6.0.0",
    "@types/mime-types": "^2.1.4",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.8.4",
    "cron": "^3.3.2",
    "csv-parser": "^3.2.0",
    "dayjs": "^1.11.13",
    "deepl-node": "^1.18.0",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.2",
    "ioredis": "^5.6.1",
    "jsforce": "^3.9.1",
    "lodash": "^4.17.21",
    "loopback-connector-postgresql": "^7.2.0",
    "loopback4-migration": "^1.3.0",
    "marked": "^16.1.1",
    "mime-types": "^3.0.1",
    "multer": "^1.4.5-lts.2",
    "sharp": "^0.34.5",
    "tslib": "^2.0.0",
    "typeorm": "^0.3.25",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@loopback/eslint-config": "^15.0.4",
    "@loopback/testlab": "^7.0.8",
    "@types/jsforce": "^1.11.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4",
    "@types/multer": "^1",
    "@types/node": "^16.18.119",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^11.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "nodemon": "^3.1.9",
    "nyc": "^18.0.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "typescript": "4.9.4"
  },
  "packageManager": "pnpm@10.0.0"
}
